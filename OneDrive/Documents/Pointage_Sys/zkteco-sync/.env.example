# IP de la machine ZKTeco sur le réseau local
ZKTECO_IP=192.168.1.100

# Port de communication (par défaut 4370)
ZKTECO_PORT=4370

# URL de l'API Laravel
API_URL=http://localhost:8000/api/sync/logs

# Clé secrète partagée avec Laravel (doit correspondre à API_SYNC_SECRET dans .env Laravel)
API_SYNC_SECRET=change_me_in_production

# Intervalle de synchronisation en secondes (300 = toutes les 5 minutes)
SYNC_INTERVAL=300
